# Report and collection limits
HARNESS_MIN_REPORT_PAGES=10
HARNESS_MAX_SOURCES=24
HARNESS_MAX_EVIDENCE_CHARS=60000

# Optional OpenAI-compatible cloud provider
HARNESS_CLOUD_BASE_URL=https://api.openai.com/v1
HARNESS_CLOUD_MODEL=
HARNESS_CLOUD_EMBED_MODEL=text-embedding-3-small
HARNESS_CLOUD_API_KEY=

# Optional private sources
HARNESS_SUBSTACK_FEEDS=
HARNESS_X_BEARER_TOKEN=
HARNESS_X_USER_ID=
HARNESS_X_MAX_ACCOUNTS=100
HARNESS_X_POSTS_PER_ACCOUNT=5

# Optional browser fallback
HARNESS_BROWSER_CDP_URL=

# Optional link-only notifications
HARNESS_NTFY_URL=
HARNESS_SMTP_HOST=
HARNESS_SMTP_PORT=587
HARNESS_SMTP_USERNAME=
HARNESS_SMTP_PASSWORD=
HARNESS_NOTIFY_EMAIL_FROM=
HARNESS_NOTIFY_EMAIL_TO=
